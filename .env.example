# Copy to .env and adjust as needed.

# --- LLM (Ollama, OpenAI-compatible) ---
# Inside Docker, reach the host's Ollama via host.docker.internal.
# If running the API outside Docker, use http://localhost:11434/v1
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct

# --- Postgres ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/docintel

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chunks

# --- Retrieval tuning ---
RETRIEVE_TOP_K=20
RERANK_TOP_K=5
# fp16 for the embed/rerank models. Leave unset for auto (fp16 on GPU, fp32 on
# CPU). Requires a CUDA build of torch to actually use the GPU.
# USE_FP16=true

# --- Storage ---
UPLOAD_DIR=/app/data/uploads
